@model WebLibrary.Models.Loan

<h2>Borrow a Book</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Member</label>
        <select name="MemberId" class="form-control" asp-items="ViewBag.MemberId"></select>
    </div>

    <div class="form-group">
        <label>Book</label>
        <select name="BookId" class="form-control" asp-items="ViewBag.BookId"></select>
    </div>

    <br />
    <input type="submit" value="Borrow" class="btn btn-primary" />
</form>

<br />
<a asp-action="Index">Back to List</a>
