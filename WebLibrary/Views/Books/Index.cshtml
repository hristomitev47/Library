@model IEnumerable<WebLibrary.Models.Book>

<h2>Books</h2>

@if (User.IsInRole("Staff"))
{
    <a href="/Books/Create" class="add-link">+ Add Book</a>
}

<table>
    <thead>
        <tr>
            <th>Cover</th>
            <th>Title</th>
            <th>Authors</th>
            <th>Genres</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(book.ImagePath))
                    {
                        <img src="@book.ImagePath" style="width:50px;height:70px;object-fit:cover;border-radius:4px;" />
                    }
                    else
                    {
                        <div style="width:50px;height:70px;background:#e0d8c8;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:#888;">No cover</div>
                    }
                </td>
                <td>@book.Title</td>
                <td>
                    @foreach (var a in book.BookAuthors)
                    {
                        @a.Author?.FullName
                        <br />
                    }
                </td>
                <td>
                    @foreach (var g in book.BookGenres)
                    {
                        @g.Genre?.Name
                        <br />
                    }
                </td>
                <td>
                    <a href="/Books/Details/@book.BookId">Details</a>

                    @if (User.IsInRole("Member"))
                    {
                        <span> | </span>
                        <a href="/Loans/Create?bookId=@book.BookId">Borrow</a>
                    }

                    @if (User.IsInRole("Staff"))
                    {
                        <span> | </span>
                        <a href="/Books/Edit/@book.BookId">Edit</a>
                        <span> | </span>
                        <a href="/Books/Delete/@book.BookId">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
