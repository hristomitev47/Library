@model WebLibrary.Models.Book

<h2>Edit Book</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="BookId" />
    <input type="hidden" asp-for="ImagePath" />

    <div class="mb-2">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-2">
        <label>ISBN</label>
        <input asp-for="Isbn" class="form-control" />
    </div>
    <div class="mb-2">
        <label>Year</label>
        <input asp-for="PublishedYear" class="form-control" />
    </div>
    <div class="mb-2">
        <label>Copies</label>
        <input asp-for="CopiesTotal" class="form-control" />
    </div>
    <div class="mb-2">
        <label>Description</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    </div>

    <div class="mb-3">
        <label>Book Cover Image</label><br />
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" style="max-width:120px; border-radius:4px; margin-bottom:0.5rem;" /><br />
            <small>Upload a new image to replace the current one</small><br />
        }
        <input type="file" name="imageFile" class="form-control mt-1" accept="image/*" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
